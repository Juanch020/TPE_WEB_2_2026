<h2>Administrar jugadores</h2>

<a
    class="btn-add"
    href="<?= BASE_URL ?>admin_jugador_add"
>
    Agregar jugador
</a>

<?php if (empty($jugadores)): ?>

    <p>No hay jugadores disponibles.</p>

<?php else: ?>

    <table class="admin-table">

        <thead>

            <tr>
                <th>ID</th>
                <th>Foto</th>
                <th>Nombre</th>
                <th>Equipo</th>
                <th>Posición</th>
                <th>Precio</th>
                <th>Acciones</th>
            </tr>

        </thead>

        <tbody>

            <?php foreach ($jugadores as $jugador): ?>

                <tr>

                    <td>
                        <?= htmlspecialchars($jugador->id) ?>
                    </td>

                    <td>

                        <?php if (!empty($jugador->foto)): ?>

                            <img
                                src="<?= htmlspecialchars($jugador->foto) ?>"
                                alt="<?= htmlspecialchars($jugador->nombre) ?>"
                                class="tabla-imagen"
                            >

                        <?php else: ?>

                            Sin foto

                        <?php endif; ?>

                    </td>

                    <td>
                        <?= htmlspecialchars($jugador->nombre) ?>
                    </td>

                    <td>
                        <?= htmlspecialchars($jugador->equipo) ?>
                    </td>

                    <td>
                        <?= htmlspecialchars($jugador->posicion) ?>
                    </td>

                    <td>
                        $<?= number_format($jugador->precio, 2, ',', '.') ?>
                    </td>

                    <td class="acciones">

                        <a
                            class="btn-edit"
                            href="<?= BASE_URL ?>admin_jugador_edit/<?= $jugador->id ?>"
                        >
                            Editar
                        </a>

                        <a
                            class="btn-delete"
                            href="<?= BASE_URL ?>admin_jugador_delete/<?= $jugador->id ?>"
                            onclick="return confirm('¿Eliminar jugador?')"
                        >
                            Eliminar
                        </a>

                    </td>

                </tr>

            <?php endforeach; ?>

        </tbody>

    </table>

<?php endif; ?>