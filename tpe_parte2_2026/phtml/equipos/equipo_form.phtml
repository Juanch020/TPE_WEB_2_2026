    : BASE_URL . "admin_equipo_add";
?>

<h2>

    <?= $isEdit ? "Editar equipo" : "Agregar equipo"; ?>

</h2>

<?php if (!empty($error)): ?>

    <p class="error-message">

        <?= htmlspecialchars($error); ?>

    </p>

<?php endif; ?>

<form action="<?= $actionUrl; ?>" method="POST">

    <div class="form-group">

        <label for="nombre">
            Nombre
        </label>

        <input
            type="text"
            id="nombre"
            name="nombre"
            required
            value="<?= $isEdit ? htmlspecialchars($equipo->nombre) : ''; ?>"
