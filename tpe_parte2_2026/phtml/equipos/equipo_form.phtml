            required
            value="<?= $isEdit ? htmlspecialchars($equipo->fecha_creacion) : ''; ?>"
        >

    </div>

    <div class="form-group">

        <label for="foto">
            URL de la foto
        </label>

        <input
            type="text"
            id="foto"
            name="foto"
            value="<?= $isEdit ? htmlspecialchars($equipo->foto) : ''; ?>"
